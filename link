#!/usr/bin/env python3
"""
Declarative symlink/copy manager for dotfiles.
Reads .link.json files from provided directories.
Configs may include nested subdirectories with more .link.json files.
"""

import os
import sys
import json
import platform
import shutil
from functools import partial
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Callable, Literal

OS_NAMES = {"windows": "Windows", "macos": "Darwin", "linux": "Linux"}
LINK_FILE_NAME = ".link.json"


def color(text: str, code: int) -> str:
    if not sys.stdout.isatty():
        return text
    return f"\033[{code}m{text}\033[0m"


red = partial(color, code=31)
green = partial(color, code=32)
yellow = partial(color, code=33)
blue = partial(color, code=34)
magenta = partial(color, code=35)
cyan = partial(color, code=36)


def is_windows() -> bool:
    return platform.system() == "Windows" or "WINDIR" in os.environ


def executable_exists(name: str) -> bool:
    return shutil.which(name) is not None


def path_exists(path: str) -> bool:
    return Path(path).expanduser().exists()


def create_symlink(source_path: Path, target_path: Path, force: bool = True) -> None:
    target_path.parent.mkdir(parents=True, exist_ok=True)

    if force and (target_path.exists() or target_path.is_symlink()):
        if target_path.is_dir() and not target_path.is_symlink():
            shutil.rmtree(target_path)
        else:
            target_path.unlink()

    # Windows requires target_is_directory=True for directory symlinks
    target_is_directory = source_path.exists() and source_path.is_dir()

    os.symlink(source_path, target_path, target_is_directory=target_is_directory)


def create_copy(source_path: Path, target_path: Path) -> None:
    target_path.parent.mkdir(parents=True, exist_ok=True)

    if source_path.is_dir():
        shutil.copytree(source_path, target_path, dirs_exist_ok=True)
    else:
        shutil.copy2(source_path, target_path)


LinkMethod = tuple[Callable[[Path, Path], None], str]

LINK_METHODS: dict[str, LinkMethod] = {
    "symlink": (create_symlink, "linking"),
    "copy": (create_copy, "copying"),
}


Condition = dict[str, "str | list[Condition]"]
ConditionResult = tuple[Literal[True], None] | tuple[Literal[False], str]


def path_exists_condition(value: str) -> ConditionResult:
    if not path_exists(value):
        return False, f"path {value} does not exist"
    return True, None


def executable_exists_condition(value: str) -> ConditionResult:
    if not executable_exists(value):
        return False, f"{value} is not executable"
    return True, None


def os_condition(value: str) -> ConditionResult:
    negate = value.startswith("!")
    os_name = value.lstrip("!")
    matched = platform.system() == OS_NAMES.get(os_name, None)
    if matched == negate:
        return False, f"os is not {value}"
    return True, None


def any_condition(conditions: list[Condition]) -> ConditionResult:
    reasons: list[str] = []
    for sub in conditions:
        met, reason = resolve_condition(sub)
        if met:
            return True, None
        reasons.append(str(reason))
    return False, f"any: [{', '.join(reasons)}]" if reasons else "no subconditions"


def all_condition(conditions: list[Condition]) -> ConditionResult:
    for sub in conditions:
        met, reason = resolve_condition(sub)
        if not met:
            return False, str(reason)
    return True, None


ValueConditionFunc = Callable[[str], ConditionResult]
CombinatorConditionFunc = Callable[[list["Condition"]], ConditionResult]

VALUE_CONDITION_FUNCS: dict[str, ValueConditionFunc] = {
    "path-exists": path_exists_condition,
    "executable-exists": executable_exists_condition,
    "os": os_condition,
}

COMBINATOR_CONDITION_FUNCS: dict[str, CombinatorConditionFunc] = {
    "any": any_condition,
    "all": all_condition,
}


def resolve_condition(condition: Condition) -> ConditionResult:
    for cond_type, cond_value in condition.items():
        combinator_condition_func = COMBINATOR_CONDITION_FUNCS.get(cond_type, None)
        if combinator_condition_func:
            if not isinstance(cond_value, list):
                return False, f"list of subconditions expected for '{cond_type}'"

            met, reason = combinator_condition_func(cond_value)
            if not met:
                return False, str(reason)

            continue

        value_condition_func = VALUE_CONDITION_FUNCS.get(cond_type, None)
        if not value_condition_func:
            return False, f"not implemented condition '{cond_type}'"

        if not isinstance(cond_value, str):
            return False, f"string value expected for '{cond_type}'"

        met, reason = value_condition_func(cond_value)
        if not met:
            return False, str(reason)

    return True, None


LinkConfig = dict[str, Any]


@dataclass(frozen=True)
class LinkFile:
    config: LinkConfig
    path: Path


@dataclass(frozen=True)
class LinkFileDiscovery:
    file: LinkFile
    skip_reason: str | None = None


def display_path(path: Path) -> str:
    relative_path = os.path.relpath(path)
    return relative_path if not relative_path.startswith("..") else str(path)


def normalize_link_file_path(path: Path) -> Path:
    normalized_path = Path(os.path.abspath(path))
    if normalized_path != normalized_path.resolve():
        raise RuntimeError(
            f"link file path must not go through a symlink: {normalized_path}"
        )

    return normalized_path


def get_included_link_file_paths(link_file: LinkFile) -> list[Path]:
    return [
        link_file.path.parent / include_dir / LINK_FILE_NAME
        for include_dir in link_file.config.get("include", [])
    ]


def discover_link_files(
    link_file_path: Path,
    visited_link_files: set[Path],
) -> list[LinkFileDiscovery]:
    link_file_path = normalize_link_file_path(link_file_path)
    if link_file_path in visited_link_files:
        return []

    visited_link_files.add(link_file_path)

    with link_file_path.open("r") as file:
        link_file = LinkFile(
            config=json.load(file),
            path=link_file_path,
        )

    if file_condition := link_file.config.get("if", None):
        condition_met, reason = resolve_condition(file_condition)
        if not condition_met:
            return [LinkFileDiscovery(link_file, str(reason))]

    discovered_link_files = [LinkFileDiscovery(link_file)]

    for included_path in get_included_link_file_paths(link_file):
        if not included_path.is_file():
            discovered_link_files.append(
                LinkFileDiscovery(LinkFile({}, included_path), "not found")
            )
            continue

        discovered_link_files.extend(
            discover_link_files(included_path, visited_link_files)
        )

    return discovered_link_files


def discover_link_files_root(link_dirs: list[str]) -> list[LinkFileDiscovery]:
    discoveries: list[LinkFileDiscovery] = []
    visited_paths: set[Path] = set()

    for link_dir in link_dirs:
        link_dir_path = Path(link_dir)
        if not link_dir_path.is_dir():
            continue

        link_file_path = Path(os.path.abspath(link_dir_path / LINK_FILE_NAME))
        if not link_file_path.is_file():
            continue

        discoveries.extend(discover_link_files(link_file_path, visited_paths))

    return discoveries


def process_link_file(link_file: LinkFile) -> None:
    for link in link_file.config["links"]:
        source = link["from"]
        target = link["to"]
        method = link.get("method", "symlink")

        if link_condition := link.get("if", None):
            condition_met, reason = resolve_condition(link_condition)
            if not condition_met:
                print(f"{cyan('skipped')} {source} {magenta(f'({reason})')}")
                continue

        source_path = (link_file.path.parent / source).resolve()
        target_path = Path(target).expanduser()

        func, label = LINK_METHODS[method]
        print(f"{yellow(label)} {source} {green('->')} {target}")
        func(source_path, target_path)


def start() -> int:
    link_dirs = sys.argv[1:]
    number_of_link_dirs = len(link_dirs)

    if number_of_link_dirs == 0:
        print(f"usage: {sys.argv[0]} <directories>...")
        return 1

    link_file_discoveries = discover_link_files_root(link_dirs)
    number_of_link_files = len(link_file_discoveries)

    for discovery in link_file_discoveries:
        if number_of_link_files > 1 or discovery.skip_reason is not None:
            print(green(f"# {display_path(discovery.file.path)}"))

        if discovery.skip_reason is not None:
            for included_link_file_path in get_included_link_file_paths(discovery.file):
                print(green(f"# ↳ {display_path(included_link_file_path)}"))

            print(f"{cyan('skipped')} {magenta(f'({discovery.skip_reason})')}")
            continue

        process_link_file(discovery.file)

    return 0


def main() -> int:
    try:
        return start()
    except Exception as error:
        print(f"\nerror: {type(error)} exception")
        print(error)
        return 1


if __name__ == "__main__":
    sys.exit(main())
