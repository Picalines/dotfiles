#!/usr/bin/env python3

import os
import sys
import json
import platform
import shutil


OS_NAMES = {"windows": "Windows", "macos": "Darwin", "linux": "Linux"}


def color(text, code):
    if not sys.stdout.isatty():
        return text
    return f"\033[{code}m{text}\033[0m"


def is_windows():
    return platform.system() == "Windows" or "WINDIR" in os.environ


def executable_exists(name):
    return shutil.which(name) is not None


def path_exists(path):
    return os.path.exists(os.path.expanduser(path))


def create_symlink(source_path, target_path, force=True):
    parent_dir = os.path.dirname(target_path)
    if parent_dir:
        os.makedirs(parent_dir, exist_ok=True)

    if force and os.path.lexists(target_path):
        if os.path.isdir(target_path) and not os.path.islink(target_path):
            shutil.rmtree(target_path)
        else:
            os.remove(target_path)

    # Windows requires target_is_directory=True for directory symlinks
    target_is_directory = False
    if os.path.exists(source_path):
        target_is_directory = os.path.isdir(source_path)

    os.symlink(source_path, target_path, target_is_directory=target_is_directory)


def create_copy(source_path, target_path):
    parent_dir = os.path.dirname(target_path)
    if parent_dir:
        os.makedirs(parent_dir, exist_ok=True)

    if os.path.isdir(source_path):
        shutil.copytree(source_path, target_path, dirs_exist_ok=True)
    else:
        shutil.copy2(source_path, target_path)


LINK_METHODS = {
    "symlink": (create_symlink, "linking"),
    "copy": (create_copy, "copying")
}


def path_exists_condition(value: str):
    if not path_exists(value):
        return False, f"path {value} does not exist"
    return True, None


def executable_exists_condition(value: str):
    if not executable_exists(value):
        return False, f"{value} is not executable"
    return True, None


def os_condition(value: str):
    negate = value.startswith("!")
    os_name = value.lstrip("!")
    matched = platform.system() == OS_NAMES.get(os_name, None)
    if matched == negate:
        return False, f"os is not {value}"
    return True, None


CONDITION_FUNCS = {
    'path-exists': path_exists_condition,
    'executable-exists': executable_exists_condition,
    'os': os_condition,
}


def resolve_condition(condition):
    for cond_type, cond_value in condition.items():
        condition_func = CONDITION_FUNCS.get(cond_type, None)

        if not condition_func:
            return False, f"not implemented condition {cond_type}"

        condition_met, reason = condition_func(cond_value)
        if not condition_met:
            return False, str(reason)

    return True, None


def process_link_file(link_file_path):
    base_dir = os.path.dirname(link_file_path)
    
    with open(link_file_path, 'r') as f:
        config = json.load(f)
    
    if file_condition := config.get('if', None):
        condition_met, reason = resolve_condition(file_condition)
        if not condition_met:
            print(f"skip: {reason}")
            return
    
    for link in config['links']:
        source = link['from']
        target = link['to']
        method = link.get('method', 'symlink')

        if link_condition := link.get('if', None):
            condition_met, reason = resolve_condition(link_condition)
            if not condition_met:
                print(f"{color('skipped', 36)} {source} {color(f"({reason})", 35)}")
                continue

        source_path = os.path.abspath(os.path.join(base_dir, source))
        target_path = os.path.expanduser(target)

        func, label = LINK_METHODS[method]
        print(f"{color(label, 33)} {source} -> {target}")
        func(source_path, target_path)


def start():
    link_files = sys.argv[1:]
    number_of_link_files = len(link_files)

    if number_of_link_files == 0:
        print(f"usage: {sys.argv[0]} <path-to-link-files>...")
        return 1

    for link_file in link_files:
        if number_of_link_files > 1:
            print(color(f'# {link_file}', 32))
        process_link_file(link_file)

    return 0


def main():
    try:
        return start()
    except Exception as error:
        print(f"\nerror: {type(error)} exception")
        print(error)
        return 1


if __name__ == "__main__":
    sys.exit(main())
