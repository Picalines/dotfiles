{
  "if": { "executable-exists": "git" },
  "links": [
    { "from": ".gitconfig", "to": "~/.gitconfig" },
    { "from": ".gitignore.global", "to": "~/.gitignore" },
    {
      "if": { "executable-exists": "lazygit" },
      "from": "lazygit.yml",
      "to": "~/.config/lazygit/config.yml"
    }
  ]
}
