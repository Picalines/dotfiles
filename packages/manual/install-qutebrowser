#!/bin/bash

YELLOW=$'\033[1;33m'
GREEN=$'\033[1;32m'
RESET=$'\033[0m'

set -euo pipefail

cd "$(dirname "${BASH_SOURCE[0]}")" || exit 1

QUTEBROWSER_REPO_URL="git@github.com:qutebrowser/qutebrowser.git"
DIST_DIR="dist"

usage() {
    echo "usage: $0 --clone-dir <qutebrowser-clone-dir>"
}

TARGET_CLONE_DIR=""

while [[ $# -gt 0 ]]; do
    case "$1" in
    --clone-dir)
        [[ $# -ge 2 ]] || {
            usage
            exit 1
        }
        TARGET_CLONE_DIR="$2"
        shift 2
        ;;
    *)
        usage
        exit 1
        ;;
    esac
done


if [[ -z "$TARGET_CLONE_DIR" ]]; then
    usage
    exit 1
fi

echo "${YELLOW}====== Detecting Homebrew python installation ======${RESET}"

detect_brew_python() {
    local prefix

    prefix="$(brew --prefix python 2>/dev/null || true)"
    if [[ -n "$prefix" && -x "$prefix/bin/python3" ]]; then
        printf '%s\n' "$prefix/bin/python3"
        return 0
    fi

    return 1
}

PYTHON_BIN="$(detect_brew_python)" || {
    echo "Could not find a usable Homebrew python installation"
    echo "install with: brew install python"
    exit 1
}

echo "Using $PYTHON_BIN"

echo "${YELLOW}====== PyQt GPL license acknowledgement ======${RESET}"
echo "This build installs PyQt6 and PyQt6-WebEngine from source with --confirm-license."
echo "By continuing, you acknowledge the GPL license terms for PyQt."
read -r -p "Continue? [y/N]: " confirm_gpl
if [[ ! "$confirm_gpl" =~ ^([yY]|yes|YES)$ ]]; then
    echo "aborted: GPL license not acknowledged"
    exit 1
fi

START_SECONDS=$SECONDS

echo "${YELLOW}====== Preparing qutebrowser checkout ======${RESET}"
echo "target: $TARGET_CLONE_DIR"

if [[ -d "$TARGET_CLONE_DIR/.git" ]]; then
    origin_url="$(git -C "$TARGET_CLONE_DIR" remote get-url origin)"
    if [[ "$origin_url" != "$QUTEBROWSER_REPO_URL" ]]; then
        echo "existing repo origin mismatch: $origin_url"
        echo "expected: $QUTEBROWSER_REPO_URL"
        exit 1
    fi

    git -C "$TARGET_CLONE_DIR" fetch --prune origin
else
    if [[ -e "$TARGET_CLONE_DIR" ]]; then
        echo "target exists and is not a git checkout: $TARGET_CLONE_DIR"
        exit 1
    fi

    git clone --depth 1 "$QUTEBROWSER_REPO_URL" "$TARGET_CLONE_DIR"
fi

git -C "$TARGET_CLONE_DIR" remote set-head origin --auto >/dev/null 2>&1 || true
remote_head_ref="$(git -C "$TARGET_CLONE_DIR" symbolic-ref refs/remotes/origin/HEAD)"
default_branch="${remote_head_ref#refs/remotes/origin/}"

git -C "$TARGET_CLONE_DIR" checkout -B "$default_branch" "$remote_head_ref"
git -C "$TARGET_CLONE_DIR" reset --hard "$remote_head_ref"
git -C "$TARGET_CLONE_DIR" clean -fdx

(
cd "$TARGET_CLONE_DIR" || exit 1

VENV_DIR=".venv"
VENV_PYTHON="$VENV_DIR/bin/python3"
BUILD_SPEC="misc/.qutebrowser.spec.local.spec"

echo "${YELLOW}====== Cleaning previous build attempts ======${RESET}"

rm -rf "$VENV_DIR" "$DIST_DIR"
rm -f "$BUILD_SPEC"
trap 'rm -f "$BUILD_SPEC"' EXIT

"$PYTHON_BIN" ./scripts/mkvenv.py \
    --venv-dir "$VENV_DIR" \
    --pyqt-type skip \
    --skip-docs \
    --skip-smoke-test

echo "${YELLOW}====== Installing PyQt6 from source ======${RESET}"

"$VENV_PYTHON" -m pip install PyQt6_sip

"$VENV_PYTHON" -m pip install PyQt6 \
    --no-deps \
    --no-binary PyQt6 \
    --config-settings="--confirm-license=" \
    --verbose

echo "${YELLOW}====== Installing PyQt6-WebEngine from source ======${RESET}"

"$VENV_PYTHON" -m pip install PyQt6-WebEngine \
    --no-deps \
    --no-binary PyQt6-WebEngine \
    --verbose

echo "${YELLOW}====== Installing pyinstaller from source ======${RESET}"

"$VENV_PYTHON" -m pip install \
    -r misc/requirements/requirements-pyinstaller.txt

echo "${YELLOW}====== Updating 3rdparty assets for release build ======${RESET}"

"$VENV_PYTHON" scripts/dev/update_3rdparty.py

if [[ ! -d qutebrowser/html/doc ]]; then
    mkdir -p qutebrowser/html/doc
fi

echo "${YELLOW}====== Patching the PyInstaller spec ======${RESET}"

cp misc/qutebrowser.spec "$BUILD_SPEC"
patch "$BUILD_SPEC" <<'PATCH'
--- misc/qutebrowser.spec
+++ misc/qutebrowser.spec
@@ -7,6 +7,7 @@
 from scripts import setupcommon

 import qutebrowser
+from PyQt6.QtCore import QLibraryInfo
 from qutebrowser.extensions import loader

 block_cipher = None
@@ -130,6 +131,24 @@ def get_hidden_imports():
     return imports


+def get_qt_plugin_binaries():
+    plugins_dir = QLibraryInfo.path(QLibraryInfo.LibraryPath.PluginsPath)
+    if not plugins_dir or not os.path.isdir(plugins_dir):
+        return []
+
+    binaries = []
+    for root, _dirs, files in os.walk(plugins_dir, followlinks=True):
+        rel_dir = os.path.relpath(root, plugins_dir)
+        for name in files:
+            if not name.endswith('.dylib'):
+                continue
+            src = os.path.join(root, name)
+            dest = os.path.join('PyQt6', 'Qt6', 'plugins', rel_dir)
+            binaries.append((src, dest))
+
+    return binaries
+
+
 setupcommon.write_git_file()


@@ -151,7 +170,7 @@ else:

 a = Analysis(['../qutebrowser/__main__.py'],
              pathex=['misc'],
-             binaries=None,
+             binaries=get_qt_plugin_binaries(),
              datas=get_data_files(),
              hiddenimports=get_hidden_imports(),
              hookspath=[],
PATCH

"$VENV_DIR/bin/pyinstaller" --noconfirm --distpath "$DIST_DIR" "$BUILD_SPEC"
)

ELAPSED_SECONDS=$((SECONDS - START_SECONDS))
COMMIT_HASH="$(git -C "$TARGET_CLONE_DIR" rev-parse --short HEAD)"

echo "${GREEN}====== Done! ======${RESET}"
echo "commit: $COMMIT_HASH"
echo "elapsed: ${ELAPSED_SECONDS}s"
echo "build: $TARGET_CLONE_DIR/$DIST_DIR"
