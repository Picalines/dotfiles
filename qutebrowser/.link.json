{
  "if": {
    "any": [
      {
        "executable-exists": "qutebrowser"
      },
      {
        "path-exists": "/Applications/qutebrowser.app"
      },
      {
        "path-exists": "~/AppData/Roaming/qutebrowser"
      }
    ]
  },
  "links": [
    {
      "from": ".",
      "to": "~/AppData/Roaming/qutebrowser/config",
      "if": {
        "os": "windows"
      }
    },
    {
      "from": ".",
      "to": "~/.qutebrowser",
      "if": {
        "os": "!windows"
      }
    }
  ]
}
